NODE_ENV=production

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=3000

# ─── Web ──────────────────────────────────────────────────────────────────────
# Internal container port only.
# Do NOT publish host port 3001 — Uptime Kuma already uses it.
WEB_PORT=3001

# ─── Local proxy ──────────────────────────────────────────────────────────────
# Binds to 127.0.0.1:8080. Access via SSH tunnel:
#   ssh -L 8080:localhost:8080 oreo@SERVER_IP
PROXY_PORT=8080

# ─── Next.js public API path ──────────────────────────────────────────────────
# Baked into the web image at build time.
# The proxy forwards /api/* to the API container.
# If you change this, you must rebuild the web image.
NEXT_PUBLIC_API_BASE_URL=/api

# ─── Swagger ──────────────────────────────────────────────────────────────────
# Keep true for private demos. Disable before any real public deployment.
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# ─── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=intake_os
POSTGRES_PASSWORD=change_me_server_password
POSTGRES_DB=intake_os
POSTGRES_PORT=5432

# API container connects to Postgres using the Docker service name.
DATABASE_URL=postgresql://intake_os:change_me_server_password@postgres:5432/intake_os?schema=public

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Set to google for real user auth. Set to dev_headers for seeding/smoke scripts.
AUTH_MODE=google

# Google OAuth — register callback at:
#   AUTH_PUBLIC_BASE_URL + AUTH_GOOGLE_CALLBACK_PATH
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# Browser-visible URL. For SSH tunnel access use http://localhost:8080.
# For Tailscale Serve/Funnel use the browser-visible HTTPS URL.
AUTH_PUBLIC_BASE_URL=http://localhost:8080
AUTH_GOOGLE_CALLBACK_PATH=/api/auth/google/callback

AUTH_LOGIN_SUCCESS_REDIRECT=/intakes
AUTH_LOGIN_FAILURE_REDIRECT=/login?error=auth_failed

# Session cookie
AUTH_SESSION_COOKIE_NAME=intake_os_session
AUTH_SESSION_TTL_HOURS=8
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax

# Access control — comma-separated emails and/or domains
AUTH_ALLOWED_DOMAINS=
AUTH_ALLOWED_EMAILS=
AUTH_ADMIN_EMAILS=
AUTH_INTAKE_OWNER_EMAILS=
AUTH_DEVOPS_LEAD_EMAILS=
AUTH_DEVELOPER_EMAILS=
AUTH_DEFAULT_ROLE=request_creator

# CORS
WEB_ORIGIN=http://localhost:8080

# Auth mode baked into Next.js web build.
# Must rebuild web image after changing.
NEXT_PUBLIC_AUTH_MODE=google

# AI provider — set to mock (default), openai, anthropic, or bedrock
AI_PROVIDER=mock

# OpenAI — required when AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=

# Anthropic — required when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Bedrock — required when AI_PROVIDER=bedrock (uses AWS SDK default credential chain)
AWS_REGION=ap-southeast-1
AWS_BEDROCK_MODEL_ID=

# AI generation tuning (optional — defaults shown)
# AI_MAX_INPUT_CHARS=12000
# AI_MAX_OUTPUT_TOKENS=2500
# AI_TEMPERATURE=0.2
