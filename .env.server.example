NODE_ENV=production

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
# apps/api/src/main.ts reads PORT (not API_PORT) — default 3000 if unset.
PORT=3000

# ─── Web ──────────────────────────────────────────────────────────────────────
# Internal container port only.
# Do NOT publish host port 3001 — Uptime Kuma already uses it.
WEB_PORT=3001

# ─── Local proxy ──────────────────────────────────────────────────────────────
# Binds to 127.0.0.1:8080. Access via SSH tunnel:
#   ssh -L 8080:localhost:8080 oreo@SERVER_IP
PROXY_PORT=8080

# ─── Next.js public API path ──────────────────────────────────────────────────
# Baked into the web image at build time.
# The proxy forwards /api/* to the API container.
# If you change this, you must rebuild the web image.
NEXT_PUBLIC_API_BASE_URL=/api

# ─── Swagger ──────────────────────────────────────────────────────────────────
# Keep true for private demos. Disable before any real public deployment.
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# ─── Postgres ─────────────────────────────────────────────────────────────────
POSTGRES_USER=intake_os
POSTGRES_PASSWORD=change_me_server_password
POSTGRES_DB=intake_os
POSTGRES_PORT=5432

# API container connects to Postgres using the Docker service name.
DATABASE_URL=postgresql://intake_os:change_me_server_password@postgres:5432/intake_os?schema=public

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Must be google here — NODE_ENV=production above makes startup refuse dev_headers.
# For seeding/smoke scripts against this server, use AUTH_SERVICE_TOKENS below instead.
AUTH_MODE=google

# Google OAuth — register callback at:
#   AUTH_PUBLIC_BASE_URL + AUTH_GOOGLE_CALLBACK_PATH
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# Browser-visible URL. For SSH tunnel access use http://localhost:8080.
# For Tailscale Serve/Funnel use the browser-visible HTTPS URL.
AUTH_PUBLIC_BASE_URL=http://localhost:8080
AUTH_GOOGLE_CALLBACK_PATH=/api/auth/google/callback

AUTH_LOGIN_SUCCESS_REDIRECT=/intakes
AUTH_LOGIN_FAILURE_REDIRECT=/login?error=auth_failed

# Session cookie
AUTH_SESSION_COOKIE_NAME=intake_os_session
AUTH_SESSION_TTL_HOURS=8
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax

# Access control — comma-separated emails and/or domains
AUTH_ALLOWED_DOMAINS=
AUTH_ALLOWED_EMAILS=
AUTH_ADMIN_EMAILS=
AUTH_INTAKE_OWNER_EMAILS=
AUTH_DEVOPS_LEAD_EMAILS=
AUTH_DEVELOPER_EMAILS=
AUTH_DEFAULT_ROLE=request_creator

# Service tokens for non-human callers (scripts, CI, webhooks) — works alongside Google
# auth, checked first. Format: "name:token:role,name:token:role". Role is fixed here,
# not from the caller. Generate tokens with: openssl rand -hex 32
# Callers send: Authorization: Bearer <token>
AUTH_SERVICE_TOKENS=

# CORS
WEB_ORIGIN=http://localhost:8080

# Auth mode baked into Next.js web build.
# Must rebuild web image after changing.
NEXT_PUBLIC_AUTH_MODE=google

# AI provider — set to mock (default), openai, anthropic, or bedrock
AI_PROVIDER=mock

# Evaluation pipeline: "orchestrator" for the multi-agent pipeline, omit/anything else
# for the legacy single-pass evaluator.
ANALYSIS_ENGINE=

# OpenAI — required when AI_PROVIDER=openai
# OPENAI_MODEL        = Discovery Engine orchestration model
# OPENAI_TASKS_MODEL  = evaluation/analysis tasks model (lighter)
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_TASKS_MODEL=

# Anthropic — required when AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Bedrock — required when AI_PROVIDER=bedrock (uses AWS SDK default credential chain)
AWS_REGION=ap-southeast-1
BEDROCK_MODEL_ID=
BEDROCK_PREMIUM_MODEL_ID=

# AI generation tuning (optional — defaults shown)
# AI_MAX_OUTPUT_TOKENS=2500
# AI_TEMPERATURE=0.2

# Provisioning executor mode for the mock registry. There is no live executor mode —
# this only ever selects a mock behavior, regardless of value.
PROVISIONING_EXECUTOR_MODE=success

# Roster API — developer-assignment scoring client. Blank disables it (no assignment
# recommendations, not an error).
ROSTER_API_URL=
ROSTER_API_KEY=

# Outbound Google Chat notifications (provisioning outcomes, dead-letter alerts). Blank
# disables notifications, not an error.
GOOGLE_CHAT_WEBHOOK_URL=

# Rate limiting — every tier has a code default; only set to override.
# RATE_LIMIT_GLOBAL_TTL=60
# RATE_LIMIT_GLOBAL_LIMIT=60
# RATE_LIMIT_INTAKE_TTL=60
# RATE_LIMIT_INTAKE_LIMIT=10
# RATE_LIMIT_AI_TTL=60
# RATE_LIMIT_AI_LIMIT=5
# RATE_LIMIT_REGEN_TTL=60
# RATE_LIMIT_REGEN_LIMIT=5
# RATE_LIMIT_MOCK_TTL=60
# RATE_LIMIT_MOCK_LIMIT=10
# RATE_LIMIT_WEBHOOK_TTL=60
# RATE_LIMIT_WEBHOOK_LIMIT=100

# ─── Not active — no live adapter reads these yet (TASK-0040) ─────────────────
# Monday/GitHub live provisioning are spec-ready but not implemented (see README
# build-state table). Setting these does nothing until docs/ai/tasks/TASK-0023D-monday-adapter.md
# and TASK-0023E-github-adapter.md are actually built.
LIVE_PROVISIONING_ENABLED=false
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=
GITHUB_ORG=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=

# App public URL — used to generate backlinks in README and Monday items once that
# adapter exists.
INTAKE_APP_URL=
