node_modules/
dist/
.env
.env.*
!.env.example
!.env.server.example
.DS_Store
__MACOSX/
coverage/
*.log

# Server runtime — never commit
.env.server

# Postgres backups (scoped to the backups/ dir — an unanchored `*.sql` here was also
# swallowing every Prisma migration.sql file under apps/api/prisma/migrations/, so none of
# them were ever actually tracked in git; found and fixed in TASK-0040)
backups/*.sql
backups/*.dump

# Next.js build output
apps/web/.next/
apps/web/tsconfig.tsbuildinfo
.gstack/

# Playwright MCP artifacts
.playwright-mcp/

# Scratch task files (repo root only — do not swallow docs/ai/tasks/TASK-####-*.md;
# also case-insensitive on macOS/Windows checkouts (core.ignorecase), so an unanchored
# pattern here matches TASK-*.md anywhere in the tree)
/task-*.md
