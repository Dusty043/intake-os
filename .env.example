# Local development placeholders only. Do not commit real secrets.
NODE_ENV=development

API_PORT=3000
API_HOST=0.0.0.0

# For running API on host machine (npm run api:start:dev):
DATABASE_URL=postgresql://intake_os:intake_os_dev@localhost:5432/intake_os?schema=public

# For running API inside Docker network (docker compose):
# DATABASE_URL=postgresql://intake_os:intake_os_dev@postgres:5432/intake_os?schema=public

POSTGRES_USER=intake_os
POSTGRES_PASSWORD=intake_os_dev
POSTGRES_DB=intake_os
POSTGRES_PORT=5432

SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# Web UI (Next.js on port 3001)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Auth mode: dev_headers (trust actor headers, for local dev/tests) or google (real OAuth)
AUTH_MODE=dev_headers

# Google OAuth — required when AUTH_MODE=google
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# Browser-visible public base URL (used to build the OAuth callback URL)
# For SSH tunnel: http://localhost:8080
AUTH_PUBLIC_BASE_URL=http://localhost:8080
AUTH_GOOGLE_CALLBACK_PATH=/api/auth/google/callback

AUTH_LOGIN_SUCCESS_REDIRECT=/intakes
AUTH_LOGIN_FAILURE_REDIRECT=/login?error=auth_failed

# Session cookie
AUTH_SESSION_COOKIE_NAME=intake_os_session
AUTH_SESSION_TTL_HOURS=8
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax

# Access control — comma-separated emails and/or domains
AUTH_ALLOWED_DOMAINS=
AUTH_ALLOWED_EMAILS=
AUTH_ADMIN_EMAILS=
AUTH_INTAKE_OWNER_EMAILS=
AUTH_DEVOPS_LEAD_EMAILS=
AUTH_DEVELOPER_EMAILS=
AUTH_DEFAULT_ROLE=request_creator

# CORS — allowed web origins when frontend and API run on different ports
WEB_ORIGIN=http://localhost:3001,http://localhost:8080

# POC actor headers (only active in AUTH_MODE=dev_headers):
# x-actor-id, x-actor-role, x-actor-name

# AI provider — set to mock (default), openai, anthropic, or bedrock
# AI_PROVIDER=mock
AI_PROVIDER=mock

# OpenAI — required when AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
OPENAI_API_KEY=
OPENAI_MODEL=

# Anthropic — required when AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5-20251001
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Bedrock — required when AI_PROVIDER=bedrock (uses AWS SDK default credential chain)
# AWS_REGION=ap-southeast-1
# BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5          # default model (Haiku 4.5) — lightweight agents
# BEDROCK_PREMIUM_MODEL_ID=anthropic.claude-sonnet-4-5 # premium model (Sonnet 4.5) — architecture, risk, synthesis
AWS_REGION=ap-southeast-1
BEDROCK_MODEL_ID=
BEDROCK_PREMIUM_MODEL_ID=

# AI generation tuning (optional — defaults shown)
# AI_MAX_INPUT_CHARS=12000
# AI_MAX_OUTPUT_TOKENS=2500
# AI_TEMPERATURE=0.2
# AI_COST_TRACKING_ENABLED=true
# AI_AUDIT_STORE_PROMPT=false

# Batch evaluation runner (used by ECS scheduled task)
# AI_BATCH_SIZE=5           # max intakes processed per ECS run
# AI_BATCH_INTERVAL_SECONDS=600  # polling cadence in seconds (10 min default)

# DynamoDB job status store — enables async batch run tracking
# DYNAMODB_JOB_STATUS_TABLE=intake-os-job-status
DYNAMODB_JOB_STATUS_TABLE=

# Downstream writes remain disabled until a separate live-integration task.
LIVE_PROVISIONING_ENABLED=false
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=18419115951
GITHUB_ORG=

# App public URL — used to generate backlinks in README and Monday items
INTAKE_APP_URL=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=
BITRIX24_WEBHOOK_URL=
