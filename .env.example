# Local development placeholders only. Do not commit real secrets.
NODE_ENV=development

API_PORT=3000
API_HOST=0.0.0.0

# For running API on host machine (npm run api:start:dev):
DATABASE_URL=postgresql://intake_os:intake_os_dev@localhost:5432/intake_os?schema=public

# For running API inside Docker network (docker compose):
# DATABASE_URL=postgresql://intake_os:intake_os_dev@postgres:5432/intake_os?schema=public

POSTGRES_USER=intake_os
POSTGRES_PASSWORD=intake_os_dev
POSTGRES_DB=intake_os
POSTGRES_PORT=5432

SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# POC-only actor simulation happens through HTTP headers:
# x-actor-id, x-actor-role, x-actor-name

# AI layer remains disabled for the MVP/POC.
AI_LAYER_ENABLED=false
AI_PROVIDER=
AWS_REGION=ap-southeast-1
AWS_BEDROCK_MODEL_ID=

# Downstream writes remain disabled until a separate live-integration task.
LIVE_PROVISIONING_ENABLED=false
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=
GITHUB_ORG=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=
BITRIX24_WEBHOOK_URL=
