# Local development placeholders only. Do not commit real secrets.
NODE_ENV=development

# apps/api/src/main.ts reads PORT (not API_PORT) — default 3000 if unset.
PORT=3000
API_HOST=0.0.0.0

# For running API on host machine (npm run api:start:dev):
DATABASE_URL=postgresql://intake_os:intake_os_dev@localhost:5432/intake_os?schema=public

# For running API inside Docker network (docker compose):
# DATABASE_URL=postgresql://intake_os:intake_os_dev@postgres:5432/intake_os?schema=public

POSTGRES_USER=intake_os
POSTGRES_PASSWORD=intake_os_dev
POSTGRES_DB=intake_os
POSTGRES_PORT=5432

SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# Web UI (Next.js on port 3001)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Auth mode: dev_headers (trust actor headers, for local dev/tests) or google (real OAuth)
AUTH_MODE=dev_headers

# Google OAuth — required when AUTH_MODE=google
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# Browser-visible public base URL (used to build the OAuth callback URL)
# For SSH tunnel: http://localhost:8080
AUTH_PUBLIC_BASE_URL=http://localhost:8080
AUTH_GOOGLE_CALLBACK_PATH=/api/auth/google/callback

AUTH_LOGIN_SUCCESS_REDIRECT=/intakes
AUTH_LOGIN_FAILURE_REDIRECT=/login?error=auth_failed

# Session cookie
# Required when AUTH_MODE=google — startup now fails fast if unset in that mode.
AUTH_SESSION_COOKIE_NAME=intake_os_session
AUTH_SESSION_TTL_HOURS=8
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax

# Access control — comma-separated emails and/or domains
AUTH_ALLOWED_DOMAINS=
AUTH_ALLOWED_EMAILS=
AUTH_ADMIN_EMAILS=
AUTH_INTAKE_OWNER_EMAILS=
AUTH_DEVOPS_LEAD_EMAILS=
AUTH_DEVELOPER_EMAILS=
AUTH_DEFAULT_ROLE=request_creator

# CORS — allowed web origins when frontend and API run on different ports
WEB_ORIGIN=http://localhost:3001,http://localhost:8080

# POC actor headers (only active in AUTH_MODE=dev_headers):
# x-actor-id, x-actor-role, x-actor-name

# AI provider — set to mock (default), openai, anthropic, or bedrock
# Dev environments should use openai. Bedrock is the preferred provider for
# staging/production. Blank values fall back to the defaults shown below —
# they no longer need to be deleted, just left empty.
# AI_PROVIDER=mock
AI_PROVIDER=mock

# Evaluation pipeline: "orchestrator" for the multi-agent pipeline, omit/anything else
# for the legacy single-pass evaluator. Read in apps/api/src/runtime/runtime.module.ts.
ANALYSIS_ENGINE=

# OpenAI — required when AI_PROVIDER=openai (dev default provider)
# OPENAI_MODEL        = Discovery Engine orchestration model (default: gpt-5.5, $5/$30 per 1M tokens)
# OPENAI_TASKS_MODEL  = evaluation/analysis tasks model — overrides OPENAI_MODEL when set
#                       gpt-5.4-mini ($0.75/$4.50 per 1M) for lighter-weight tasks
#                       gpt-5.4-nano ($0.20/$1.25 per 1M) — cheaper fallback if spend gets too high
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_TASKS_MODEL=

# Anthropic — required when AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5-20251001
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Bedrock — required when AI_PROVIDER=bedrock (uses AWS SDK default credential chain)
# AWS_REGION=ap-southeast-1
# BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5          # default model (Haiku 4.5) — lightweight agents
# BEDROCK_PREMIUM_MODEL_ID=anthropic.claude-sonnet-4-5 # premium model (Sonnet 4.5) — architecture, risk, synthesis
AWS_REGION=ap-southeast-1
BEDROCK_MODEL_ID=
BEDROCK_PREMIUM_MODEL_ID=

# AI generation tuning (optional — defaults shown)
# AI_MAX_OUTPUT_TOKENS=2500
# AI_TEMPERATURE=0.2

# Provisioning executor mode for the mock registry (success, full_failure, monday_fail,
# github_fail, monday_fail_then_succeed, github_fail_then_succeed, both_fail_then_succeed).
# Read in apps/api/src/runtime/runtime.module.ts. There is no live executor mode — this only
# ever selects a mock behavior, regardless of value.
PROVISIONING_EXECUTOR_MODE=success

# Roster API — developer-assignment scoring client. Blank disables it (no assignment
# recommendations, not an error). Read in apps/api/src/runtime/runtime.module.ts.
ROSTER_API_URL=
ROSTER_API_KEY=

# Outbound Google Chat notifications (provisioning outcomes, dead-letter alerts). Blank
# disables notifications, not an error. Read in src/application/notifications/google-chat-config.ts.
GOOGLE_CHAT_WEBHOOK_URL=

# Rate limiting — every tier has a code default; only set to override.
# RATE_LIMIT_GLOBAL_TTL=60
# RATE_LIMIT_GLOBAL_LIMIT=60
# RATE_LIMIT_INTAKE_TTL=60
# RATE_LIMIT_INTAKE_LIMIT=10
# RATE_LIMIT_AI_TTL=60
# RATE_LIMIT_AI_LIMIT=5
# RATE_LIMIT_REGEN_TTL=60
# RATE_LIMIT_REGEN_LIMIT=5
# RATE_LIMIT_MOCK_TTL=60
# RATE_LIMIT_MOCK_LIMIT=10
# RATE_LIMIT_WEBHOOK_TTL=60
# RATE_LIMIT_WEBHOOK_LIMIT=100

# ─── Not active — no live adapter reads these yet (TASK-0040) ─────────────────
# Monday/GitHub live provisioning, and the app's public URL used in their generated
# content, are spec-ready but not implemented (see README build-state table). Setting
# these does nothing until docs/ai/tasks/TASK-0023D-monday-adapter.md and
# TASK-0023E-github-adapter.md are actually built. Kept here only so the intended shape
# is visible; do not expect provisioning to go live by filling these in.
LIVE_PROVISIONING_ENABLED=false
MONDAY_API_TOKEN=
MONDAY_BOARD_ID=
GITHUB_ORG=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=
INTAKE_APP_URL=
