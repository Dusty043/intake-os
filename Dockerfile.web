FROM node:22-slim AS deps
WORKDIR /app

COPY package*.json ./
COPY apps/web/package*.json ./apps/web/
RUN npm ci
RUN npm --prefix apps/web ci

FROM node:22-slim AS build
WORKDIR /app

# NEXT_PUBLIC_* vars are baked into the Next.js build at build time.
# Rebuild the web image when these change.
ARG NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL

ARG NEXT_PUBLIC_AUTH_MODE=dev_headers
ENV NEXT_PUBLIC_AUTH_MODE=$NEXT_PUBLIC_AUTH_MODE

COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/apps/web/node_modules ./apps/web/node_modules
COPY . .
RUN npm run web:build

FROM node:22-slim AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3001

COPY package*.json ./
COPY apps/web/package*.json ./apps/web/
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/apps/web/node_modules ./apps/web/node_modules
COPY --from=build /app/apps/web/.next ./apps/web/.next
COPY apps/web/next.config.ts ./apps/web/

# Exposes only inside the Docker network — host port 3001 is reserved for Uptime Kuma.
EXPOSE 3001

CMD ["npm", "run", "web:start"]
